{
  "$schema": "https://raw.githubusercontent.com/Opencode-DCP/opencode-dynamic-context-pruning/master/dcp.schema.json",
  "autoUpdate": true,
  "pruneNotification": "detailed",
  "pruneNotificationType": "chat",
  "turnProtection": {
    "enabled": true,
    "turns": 5
  },
  "compress": {
    "mode": "range",
    "permission": "allow",
    "summaryBuffer": true,
    "minContextLimit": "12%",
    "maxContextLimit": "28%",
    "nudgeFrequency": 3,
    "iterationNudgeThreshold": 10,
    "nudgeForce": "strong",
    "protectTags": true,
    "protectUserMessages": true
  },
  "strategies": {
    "deduplication": {
      "enabled": true
    },
    "purgeErrors": {
      "enabled": true,
      "turns": 3
    }
  }
}
